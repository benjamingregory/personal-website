# --- Chat with Ben ---
# Anthropic API key for the Mastra agent powering /chat.
# Required. Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=

# ElevenLabs credentials for voice cloning + TTS on /chat.
# Required for voice output. Voice ID is the cloned voice's UUID.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# WebGL hero gradient (Paper Shaders mesh gradient + grain). Set to 'off' to disable.
NEXT_PUBLIC_WEBGL_FX=on

# Optional, local only. Path to the Kasava repo's published blog dir for the
# prebuild parity check (scripts/check-external-posts.mjs). Defaults to
# ../kasava/marketing/blogs/published; the check skips cleanly if absent (CI).
# KASAVA_BLOG_DIR=

# PostHog web analytics. Optional — analytics stay off when unset.
# Create a project at https://us.posthog.com and paste its client token (phc_...).
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
