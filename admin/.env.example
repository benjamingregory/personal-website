# --- Auth gate (src/proxy.ts) ---
# HTTP Basic Auth over the whole app. Fails closed: without ADMIN_PASSWORD the
# app serves 401 for everything.
ADMIN_USERNAME=ben
ADMIN_PASSWORD=

# --- Postgres usage metrics (read-only SELECTs) ---
# Each app's Supabase pooler URL. Sections without a URL render "db not wired".
INROLE_DATABASE_URL=
KASAVA_DATABASE_URL=
MONROE_DATABASE_URL=

# --- PostHog web analytics (visits, pageviews) ---
# Personal API key (phx_...) with query:read scope on the project's org.
# Keys differ per org: POSTHOG_API_KEY_INROLE / _KASAVA / _MONROE / _WEBSITE
# override the shared POSTHOG_API_KEY per project.
POSTHOG_API_KEY=
# POSTHOG_HOST=https://us.posthog.com
POSTHOG_PROJECT_ID_INROLE=
POSTHOG_PROJECT_ID_KASAVA=
POSTHOG_PROJECT_ID_MONROE=508303
POSTHOG_PROJECT_ID_WEBSITE=

# --- Vercel deploy checks (latest production deployment per project) ---
# Token: a scoped Vercel access token (Account Settings → Tokens). Without it
# the deploy check is silently skipped.
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID_INROLE=
VERCEL_PROJECT_ID_KASAVA=
VERCEL_PROJECT_ID_MONROE=
VERCEL_PROJECT_ID_WEBSITE=
